# ---------------------------------------------------------------------------
# Copy this file to .env (root) and adjust as needed for local development.
# docker-compose.yml and the server/web apps both read from this single file.
# ---------------------------------------------------------------------------

# NODE_ENV is intentionally not set here: Next.js and tsx/tsc each set it
# appropriately for dev vs. build/start, and forcing it via dotenv breaks
# `next build` (which requires NODE_ENV=production during the build step).

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=bmp
POSTGRES_PASSWORD=bmp_dev_password
POSTGRES_DB=bmp
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bmp:bmp_dev_password@localhost:5432/bmp?schema=public

# --- Redis ----------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object storage) ---------------------------------
MINIO_ROOT_USER=bmp_minio
MINIO_ROOT_PASSWORD=bmp_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=bmp_minio
S3_SECRET_ACCESS_KEY=bmp_minio_password
S3_BUCKET=bmp-attachments
S3_FORCE_PATH_STYLE=true

# --- Mailhog (dev SMTP) -----------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="Business Management Platform <no-reply@bmp.local>"
MAILHOG_WEB_PORT=8025

# --- Server -----------------------------------------------------------------
SERVER_PORT=4000
API_BASE_PATH=/api/v1
CORS_ORIGIN=http://localhost:3000

ACCESS_TOKEN_SECRET=dev_access_token_secret_change_me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_COOKIE_NAME=refreshToken

PASSWORD_RESET_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=48

WEB_APP_URL=http://localhost:3000

# --- Web (Next.js) -----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
WEB_PORT=3000

# --- Seed data ----------------------------------------------------------------
SEED_USER_PASSWORD=ChangeMe123!

# --- Ollama (local LLM, tender document auto-extraction) --------------------
# Optional: only needed for the "extract from document" upload on the new
# tender page. Run `ollama serve` and `ollama pull llama3.1:8b` locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
